{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3.2",
        "aacotroneo/laravel-saml2": "^2.1",
        "bezhansalleh/filament-language-switch": "^4.0",
        "binarytorch/larecipe": "^2.8",
        "directorytree/ldaprecord-laravel": "^3.4",
        "doctrine/dbal": "^3.0",
        "filament/filament": "~4.0",
        "guzzlehttp/guzzle": "^7.5",
        "laravel/framework": "^12.0",
        "laravel/octane": "^2.10",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.7",
        "league/flysystem-aws-s3-v3": "^3.30",
        "phpoffice/phpspreadsheet": "^5.5",
        "predis/predis": "^3.4",
        "tomatophp/filament-pwa": "~4.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "filament/upgrade": "^4.0",
        "fruitcake/laravel-debugbar": "^4.0",
        "laravel/pint": "^1.27",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^11.0",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/Admin/ErrorHelper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
